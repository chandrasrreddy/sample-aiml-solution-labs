{
  "mcpServers": {
    "aws-bedrock-agentcore": {
      "command": "/Users/pvsaws/miniconda3/bin/python",
      "args": ["/Users/pvsaws/Documents/Coding/Python/Kiro/agentcore-mcp-server/server.py"],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "AWS_PROFILE": "kiro-temp-agentcore"
      },
      "disabled": false,
      "autoApprove": []
    },
    "strands-agents": {
      "command": "uvx",
      "args": [
        "strands-agents-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "timeout": 60,
      "autoApprove": [
        "search_docs",
        "fetch_doc"
      ]
    },
    "bedrock-agentcore-mcp-server": {
      "command": "uvx",
      "args": [
        "awslabs.amazon-bedrock-agentcore-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "autoApprove": [
        "search_agentcore_docs",
        "fetch_agentcore_doc"
      ]
    }
  }
}
